{
  "include": ["apps/**/*.ts", "apps/**/*.vue", "components/**/*.ts", "integrations/**/*.ts", "*.d.ts", ".nodevault/build/schemas.ts"],
  "exclude": ["node_modules", "**/node_modules/*", ".nuxt", ".output", "**/.output/*", "dist", "**/.nuxt/*"],
  "compileOnSave": true,
  "typeRoots": ["./node_modules/@types"],
  "compilerOptions": {
    "types": ["node", "vitest/globals", "vite/client", "@nuxt/types", "@pinia/nuxt"],
    "allowJs": true,
    "skipLibCheck": true,
    "sourceMap": true,
    "strict": true,
    "noEmit": true,
    "incremental": true,
    "tsBuildInfoFile": "./.nodevault/.tsbuildinfo",
    "target": "ES2022",
    "module": "preserve",
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "moduleDetection": "force",
    "isolatedModules": true,
    "verbatimModuleSyntax": true,
    "noUncheckedIndexedAccess": false,
    "forceConsistentCasingInFileNames": true,
    "noImplicitOverride": true,
    "lib": ["ES2022", "dom", "dom.iterable", "webworker"],
    "jsx": "preserve",
    "jsxImportSource": "vue",
    "moduleResolution": "Bundler",
    "useDefineForClassFields": true,
    "noImplicitThis": true,
    "allowSyntheticDefaultImports": true,
    "paths": {
      "@nodevault/platform.apps.api": ["./apps/api/index.ts"],
      "@nodevault/platform.apps.nodevault": ["./apps/nodevault/index.ts"],
      "@nodevault/platform.components.api.client": ["./components/api/client/index.ts"],
      "@nodevault/platform.components.api.server": ["./components/api/server/index.ts"],
      "@nodevault/platform.components.api.schemas": ["./components/api/schemas/index.ts"],
      "@nodevault/platform.components.configuration.core": ["./components/configuration/core/index.ts"],
      "@nodevault/platform.components.configuration.server": ["./components/configuration/server/index.ts"],
      "@nodevault/platform.components.configuration.client": ["./components/configuration/client/index.ts"],
      "@nodevault/platform.components.ravendb": ["./components/ravendb/index.ts"],
      "@nodevault/platform.components.search": ["./components/search/index.ts"],
      "@nodevault/platform.components.domain": ["./components/domain/index.ts"],
      "@nodevault/platform.components.context": ["./components/context/index.ts"],
      "@nodevault/platform.components.utils": ["./components/utils/index.ts"],
      "@nodevault/platform.components.utils.server": ["./components/utils-server/index.ts"],
      "@nodevault/platform.integrations.resend": ["./integrations/resend/index.ts"],
      "@nodevault/platform.integrations.cloudflare": ["./integrations/cloudflare/index.ts"]
    }
  }
}
