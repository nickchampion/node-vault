{
  "name": "@nodevault/platform",
  "version": "1.0.0",
  "license": "MIT",
  "scripts": {
    "build": "./.nodevault/build/build.sh",
    "db": "tsx ./apps/api/migrations/index.ts",
    "compile": "tsc --noEmit",
    "lint": "nx run-many --target=lint --all --fix",
    "schemas": "tsx ./.nodevault/build/schemas.ts",
    "clean": "rm -rf apps/nodevault/.nuxt apps/nodevault/.output",
    "api": "reset && tsx watch --inspect=9228 ./apps/api/index.ts",
    "api:build": "nx reset && reset && nx build @nodevault/platform.apps.api",
    "app": "pnpm run clean && nx reset && reset && nx serve @nodevault/platform.apps.nodevault",
    "app:build": "NITRO_PRESET=cloudflare_module nx build @nodevault/platform.apps.nodevault",
    "app:cf": "./.nodevault/cloudflare/local.sh",
    "nc": "pnpm run clean && nx reset && reset && nx serve @nodevault/platform.apps.nickchampion"
  },
  "private": true,
  "type": "module",
  "dependencies": {
    "@iconify-json/lucide": "^1.2.105",
    "@iconify-json/simple-icons": "^1.2.80",
    "@nuxt/kit": "^4.4.2",
    "@nuxt/ui": "^4.7.1",
    "@nuxtjs/device": "^4.0.0",
    "@pinia/nuxt": "^0.11.3",
    "@tailwindcss/vite": "^4.2.4",
    "@vue-email/render": "^0.0.9",
    "@vueuse/components": "^14.2.1",
    "@vueuse/core": "^14.2.1",
    "@vueuse/nuxt": "^14.2.1",
    "date-fns": "^4.1.0",
    "fast-csv": "^5.0.5",
    "koa": "^3.2.0",
    "koa-body": "^7.0.1",
    "koa-compress": "^5.2.1",
    "multer": "^2.1.1",
    "nuxt": "^4.4.2",
    "openapi-backend": "^5.16.1",
    "pinia": "^3.0.4",
    "ravendb": "^7.2.1",
    "resend": "^6.12.3",
    "vue": "^3.5.30",
    "vue-router": "^5.0.4",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@nuxt/eslint-config": "^1.15.2",
    "@nuxt/types": "^2.18.1",
    "@nx/esbuild": "^22.7.1",
    "@nx/eslint": "^22.6.1",
    "@nx/js": "^22.6.1",
    "@nx/nuxt": "^22.6.1",
    "@nx/vite": "^22.6.1",
    "@nx/vue": "^22.6.1",
    "@nx/web": "^22.6.1",
    "@nx/workspace": "^22.6.1",
    "@stylistic/eslint-plugin": "^5.10.0",
    "@swc-node/register": "^1.11.1",
    "@swc/core": "^1.15.21",
    "@swc/helpers": "^0.5.19",
    "@types/koa": "^3.0.2",
    "@types/multer": "^2.1.0",
    "@types/node": "^25.5.0",
    "@vitest/eslint-plugin": "^1.6.16",
    "eslint": "^10.1.0",
    "eslint-plugin-unicorn": "^63.0.0",
    "eslint-plugin-vuejs-accessibility": "^2.5.0",
    "nuxi": "^3.35.1",
    "nx": "^22.6.1",
    "openapi-types": "^12.1.3",
    "openapi-typescript-codegen": "^0.23.0",
    "tslib": "^2.8.1",
    "tsx": "^4.21.0",
    "typescript": "^6.0.2",
    "vite": "^8.0.2",
    "vitest": "^4.1.1",
    "vue-tsc": "^3.2.6",
    "wrangler": "^4.94.0"
  }
